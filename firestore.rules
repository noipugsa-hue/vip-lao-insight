rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Login History Collection
    // ========================================
    match /login_history/{document=**} {
      // อนุญาตให้ user ที่ authenticate แล้วเขียนข้อมูลได้
      allow create: if request.auth != null;

      // อนุญาตให้ admin อ่านข้อมูลได้
      allow read: if request.auth != null &&
                     request.auth.token.email == 'noipugsa@gmail.com';
    }

    // ========================================
    // Lottery Results Collection
    // ========================================
    match /lotteryResults/{document=**} {
      // อนุญาตให้ user ที่ authenticate แล้วอ่านและเขียนได้
      allow read, write: if request.auth != null;
    }

    // ========================================
    // Purchases Collection (เลขที่ซื้อ)
    // ========================================
    match /purchases/{purchaseId} {
      // อนุญาตให้ user อ่านและเขียนเฉพาะข้อมูลของตัวเอง
      allow read, write: if request.auth != null &&
                            request.auth.uid == resource.data.userId;

      // อนุญาตให้สร้างเอกสารใหม่ได้ถ้า userId ตรงกับ auth.uid
      allow create: if request.auth != null &&
                       request.auth.uid == request.resource.data.userId;
    }

    // ========================================
    // Subscriptions Collection (สมาชิก VIP)
    // ========================================
    match /subscriptions/{userId} {
      // อนุญาตให้ user อ่านและเขียนเฉพาะข้อมูลของตัวเอง
      allow read: if request.auth != null &&
                     request.auth.uid == userId;

      // อนุญาตให้สร้างและอัพเดทเฉพาะข้อมูลของตัวเอง
      allow create, update: if request.auth != null &&
                               request.auth.uid == userId &&
                               request.auth.uid == request.resource.data.userId;

      // อนุญาตให้ admin อ่านและจัดการได้ทั้งหมด
      allow read, write: if request.auth != null &&
                            request.auth.token.email == 'noipugsa@gmail.com';
    }

    // ========================================
    // Payments Collection (ประวัติการชำระเงิน)
    // ========================================
    match /payments/{paymentId} {
      // อนุญาตให้ user อ่านเฉพาะข้อมูลของตัวเอง
      allow read: if request.auth != null &&
                     request.auth.uid == resource.data.userId;

      // อนุญาตให้สร้างเฉพาะข้อมูลของตัวเอง
      allow create: if request.auth != null &&
                       request.auth.uid == request.resource.data.userId;

      // อนุญาตให้ admin อ่านและจัดการได้ทั้งหมด
      allow read, write: if request.auth != null &&
                            request.auth.token.email == 'noipugsa@gmail.com';
    }

    // ========================================
    // Default: Block all other access
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
