rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function: Check if user is admin
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'noipugsa@gmail.com';
    }

    // Helper function: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function: Check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ========================================
    // Login History Collection
    // ========================================
    match /login_history/{document} {
      // Anyone authenticated can create their own login record
      // Simplified: just check if authenticated (userId will be validated on client)
      allow create: if isAuthenticated();

      // Only admin can read
      allow read: if isAdmin();

      // Only admin can update/delete
      allow update, delete: if isAdmin();
    }

    // ========================================
    // Lottery Results Collection
    // ========================================
    match /lotteryResults/{document=**} {
      // Anyone authenticated can read and write
      allow read, write: if isAuthenticated();
    }

    // ========================================
    // Purchases Collection (เลขที่ซื้อ)
    // ========================================
    match /purchases/{purchaseId} {
      // Admin can do everything
      allow read, write: if isAdmin();

      // Users can read their own documents
      allow read: if isAuthenticated() &&
                     resource.data.userId == request.auth.uid;

      // Users can create their own documents
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;

      // Users can update their own documents
      allow update: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;

      // Users can delete their own documents
      allow delete: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
    }

    // ========================================
    // Subscriptions Collection (สมาชิก VIP)
    // ========================================
    match /subscriptions/{userId} {
      // Admin can do everything
      allow read, write: if isAdmin();

      // Users can read their own subscription
      allow read: if isOwner(userId);

      // Users can create their own subscription
      allow create: if isOwner(userId) &&
                       request.resource.data.userId == request.auth.uid;

      // Users can update their own subscription
      allow update: if isOwner(userId) &&
                       request.resource.data.userId == request.auth.uid;
    }

    // ========================================
    // Payments Collection (ประวัติการชำระเงิน)
    // ========================================
    match /payments/{paymentId} {
      // Admin can do everything
      allow read, write: if isAdmin();

      // Users can read their own payments
      allow read: if isAuthenticated() &&
                     resource.data.userId == request.auth.uid;

      // Users can create their own payment records
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
    }

    // ========================================
    // Settings Collection (การตั้งค่าระบบ)
    // ========================================
    match /settings/{settingId} {
      // Anyone authenticated can read settings
      allow read: if isAuthenticated();

      // Only admin can write settings
      allow write: if isAdmin();
    }

    // ========================================
    // Government Lottery Collection (หวยรัฐบาล)
    // ========================================
    match /governmentLottery/{document=**} {
      // Anyone can read (public data)
      allow read: if true;

      // Anyone authenticated can write (for auto-save from API)
      allow write: if isAuthenticated();
    }

    // ========================================
    // Admin Actions Collection (Audit Log)
    // ========================================
    match /admin_actions/{actionId} {
      // Only admin can read
      allow read: if isAdmin();

      // Only admin can create (immutable audit log)
      allow create: if isAdmin();

      // No one can update or delete (preserve audit trail)
      allow update, delete: if false;
    }

    // ========================================
    // Default: Block all other access
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
